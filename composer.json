{
    "name": "mahadi/laravel-modular-kit",
    "description": "Laravel package to scaffold modules and module resources.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mahadi Hasan",
            "email": "mehedibuet11@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mahadi\\LaravelModuleMaker\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mahadi\\LaravelModuleMaker\\ModuleMakerServiceProvider"
            ]
        }
    }
}
